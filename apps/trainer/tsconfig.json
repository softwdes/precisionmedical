{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@precision/ui": [
        "../../packages/ui/src"
      ],
      "@precision/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@precision/db": [
        "../../packages/db/src"
      ],
      "@precision/db/*": [
        "../../packages/db/src/*"
      ],
      "@precision/lib": [
        "../../packages/lib/src"
      ],
      "@precision/lib/*": [
        "../../packages/lib/src/*"
      ],
      "@precision/ai": [
        "../../packages/ai/src"
      ],
      "@precision/ai/*": [
        "../../packages/ai/src/*"
      ]
    },
    "jsx": "preserve"
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
