// =====================================================
// PHOENIX (LM v3) — Phase 0 additions · NO-PHI catalogs
// Added 2026-06-05 · Erick + Claude
// =====================================================
// These models support the clinical workflow (B.17.5-B.18, B.35)
// captured from the LM legacy. They are catalog/metadata only —
// patient data (PHI) does NOT live here. Phase 1 adds PHI tables
// (patients, cases, visits, notes) AFTER BAA Supabase signs.
// =====================================================

// ─── Doctor Credentials (clinical extension of Employee) ─────────
//
// One-to-one with Employee where Employee.position = 'DOCTOR'.
// Separate table to avoid inflating Employee with NULLable
// clinical fields for the 90% of employees who are not doctors.
// All fields are clinical credentials — NOT PHI (provider data).
model DoctorCredentials {
  id                    String     @id @default(cuid())
  employeeId            String     @unique
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // National Provider Identifier — mandatory for HCFA (CMS-1500) claim submission.
  // Source: NPPES (https://npiregistry.cms.hhs.gov). Public registry.
  npiNumber             String?    @unique

  // DEA (Drug Enforcement Administration) number — required to prescribe
  // controlled substances via DAW EPCS (B.19). Restricted access.
  deaNumber             String?    @unique

  // State medical license — required to practice. State must match
  // clinic state for non-telehealth visits.
  medicalLicenseNumber  String?
  medicalLicenseState   String?    // ISO state code (e.g. "UT")

  specialty             Specialty  // Legacy enum — backward compat. Primary specialty también va en DoctorSpecialtyAssignment.
  signatureUrl          String?    // Digital signature for SOAP notes (B.21 firma)

  isActive              Boolean    @default(true)

  // Phoenix 2026-06-06: many-to-many con SpecialtyCatalog (B.36)
  specialtyAssignments  DoctorSpecialtyAssignment[]

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([npiNumber])
  @@index([deaNumber])
  @@index([specialty])
  @@map("doctor_credentials")
}

// ─── Templates (B.17.5 / B.17.6 / B.17.7) ────────────────────────
//
// Doctor note templates captured from the LM legacy. Each template
// has sections (CC/HPI/ROS/PE/Eval/Plan/Dx) which are toggleable
// per use. Sections can contain variants (tiered options), procedural
// blocks (e.g. trigger point injection), and price references (snapshot
// at signing for closing case notes → demand letter B.28).

enum TemplateScope {
  PERSONAL  // Owned by single doctor (default for new templates)
  SHARED    // Available to all doctors across all clinics
  SPECIALTY // Available only to doctors of a specific specialty
}

enum EncounterType {
  FOLLOW_UP
  NEW_PATIENT
  RE_EVAL
  URI          // Upper Respiratory Infection
  PHYSICAL     // Annual physical
  NURSING_HOME
  CLOSING      // MMI / discharge case (with future-care prices)
  OTHER
}

enum CaseType {
  MVA      // Motor Vehicle Accident — primary at Precision Medical
  GENERAL
  NURSING_HOME
}

enum TemplateSectionKey {
  QUEJA_PRINCIPAL  // Chief Complaint
  HPI              // Historia de la Enfermedad Actual (History of Present Illness)
  ROS              // Revisión de Sistemas (Review of Systems)
  EXAMEN_FISICO    // Physical Exam
  EVALUACIONES     // Assessment (tiered + causation statement for PI)
  PLAN             // Treatment plan (with variants + procedural + prices)
  DIAGNOSTICOS     // Diagnoses (ICD-10 + SNOMED dual)
}

model Template {
  id            String          @id @default(cuid())

  title         String          // e.g. "NG-MVA F/U" (prefix=doctor, suffix=encounter type)
  description   String?         // e.g. "Motor Vehicle Accident Follow-up"

  encounterType EncounterType
  caseType      CaseType        @default(GENERAL)
  scope         TemplateScope   @default(PERSONAL)

  // For SPECIALTY scope: which specialty owns this template.
  // Null for PERSONAL/SHARED.
  // NOTE: Specialty enum exists in this schema (Provider model uses it).
  specialty     Specialty?

  createdById   String
  createdBy     User            @relation("TemplateCreatedBy", fields: [createdById], references: [id])

  sections      TemplateSection[]
  favorites     TemplateFavorite[]
  visitNotes    VisitNote[]

  usageCount    Int             @default(0)
  isActive      Boolean         @default(true)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([scope])
  @@index([encounterType])
  @@index([caseType])
  @@index([createdById])
  @@index([specialty])
  @@map("templates")
}

model TemplateSection {
  id              String              @id @default(cuid())
  templateId      String
  template        Template            @relation(fields: [templateId], references: [id], onDelete: Cascade)

  sectionKey      TemplateSectionKey
  content         String              @db.Text  // HTML rich text with placeholders
  enabledByDefault Boolean            @default(true)

  // Tiered options inline (e.g. Evaluaciones Básica/Intermedia/Severa).
  // Doctor deletes variants that don't apply. JSON shape:
  // [{ label: string, content: string }]
  variants         Json?

  // Reusable procedural notes (e.g. trigger point injection narrative).
  // Conditionally activated by doctor. JSON shape:
  // [{ trigger: string, content: string, cpt_code: string, consent_required: boolean }]
  proceduralBlocks Json?

  // Price references for Closing Case notes. Snapshot taken at signing
  // (B.18 firma) — feeds demand letter (B.28). JSON shape:
  // [{ label: string, cpt_code: string }]
  priceReferences  Json?

  // Locked content blocks that require confirm to delete (e.g. PI causation
  // statement: "reasonable degree of medical certainty..."). JSON shape:
  // [{ content_substring: string, warning_message: string }]
  lockedBlocks     Json?

  orderIndex       Int                 @default(0)

  @@unique([templateId, sectionKey])
  @@index([templateId])
  @@map("template_sections")
}

model TemplateFavorite {
  id          String   @id @default(cuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("TemplateFavorites", fields: [userId], references: [id])

  // Personal usage tracking for autocomplete ranking
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?

  createdAt   DateTime @default(now())

  @@unique([templateId, userId])
  @@index([userId])
  @@index([userId, usageCount])
  @@map("template_favorites")
}

// ─── Diagnoses (B.35) — Dual ICD-10 + SNOMED CT ──────────────────
//
// Both code systems are FREE for clinical use in the US:
// - ICD-10-CM: published by CDC annually. ~70K codes.
//   https://www.cdc.gov/nchs/icd/icd-10-cm/files.html
// - SNOMED CT: licensed but FREE for US clinical use via NLM/UMLS.
//   ~350K concepts.
//   https://www.nlm.nih.gov/healthit/snomedct/index.html
//
// Pattern from legacy: each diagnosis row pairs an ICD-10 (for billing
// HCFA/CMS-1500) with an optional SNOMED (for clinical granularity +
// longitudinal reports). DiagnosisMapping table allows additional
// 1-to-many alternates if needed beyond the primary pair.

enum DiagnosisCategory {
  S        // Lesiones (Injuries) — S00-T98 in ICD-10
  T        // (continuation of S range)
  M        // Musculoesqueléticas / Musculoskeletal — M00-M99
  R        // Síntomas / Symptoms — R00-R99
  G        // Neurológicas / Neurological — G00-G99
  F        // Mental / Behavioral — F00-F99
  V_W      // External cause (accident) — V00-W99 (e.g. V43.52XA MVA codes)
  Z        // Factors influencing health — Z00-Z99
  OTHER
}

model Diagnosis {
  id                String                 @id @default(cuid())

  // Dual coding — primary pair
  icd10Code         String                 @unique
  icd10Description  String
  snomedCode        String?
  snomedDescription String?

  category          DiagnosisCategory
  bodySystem        String?                // e.g. "Cervical spine", "Lumbar spine", "Head"
  piRelevant        Boolean                @default(false)  // Flag for PI workflow

  // Usage tracking for autocomplete ranking
  usageCount        Int                    @default(0)
  isActive          Boolean                @default(true)

  favorites              UserDiagnosisFavorite[]
  mappings               DiagnosisMapping[]
  visitNoteDiagnoses     VisitNoteDiagnosis[]

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([icd10Code])
  @@index([snomedCode])
  @@index([category])
  @@index([piRelevant])
  @@map("diagnoses")
}

// Cross-reference for additional ICD-10 ↔ SNOMED mappings beyond the
// primary pair on Diagnosis. Useful when one ICD-10 has multiple valid
// SNOMED concepts of varying specificity.
model DiagnosisMapping {
  id              String     @id @default(cuid())
  diagnosisId     String
  diagnosis       Diagnosis  @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  alternateIcd10  String?
  alternateSnomed String?

  // EXACT (1:1), BROADER (alternate is more general),
  // NARROWER (alternate is more specific), RELATED (lateral concept)
  mappingType     String

  notes           String?    @db.Text

  @@index([diagnosisId])
  @@map("diagnosis_mappings")
}

model UserDiagnosisFavorite {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("DiagnosisFavorites", fields: [userId], references: [id])
  diagnosisId String
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  // Personal usage tracking for autocomplete ranking
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?

  createdAt   DateTime  @default(now())

  @@unique([userId, diagnosisId])
  @@index([userId])
  @@index([userId, usageCount])
  @@map("user_diagnosis_favorites")
}

// ─── Specialty Catalog (B.36) ─────────────────────────────────────
//
// Source-of-truth de las líneas de servicio de la clínica.
// Reemplaza al enum legacy `Specialty` (que sigue existiendo arriba
// para compatibilidad con Provider/DoctorCredentials/Template, pero
// el CRUD opera sobre esta tabla).
//
// Mockup canónico: B.36 (Catálogo de Especialidades / Service lines).
// Mejoras vs LM legacy: color picker · CPT codes sugeridos · métricas
// agregadas · soft delete · cardinalidad muchos-a-muchos con doctores.

model SpecialtyCatalog {
  id          String    @id @default(cuid())

  name        String    @unique  // "Auto Accidents", "Pain Management", etc.
  description String?
  color       String              // hex "#F43F5E" — consumido en B.10 calendar, B.17 Mi día, B.29 dashboard
  caseType    CaseType  @default(GENERAL)

  // CPT codes sugeridos — pre-cargan en B.21 al firmar nota
  cptSuggested String[]  @default([])

  // Workflow type asociado:
  // - 'MVA' → flujo PI con lien
  // - 'GM'  → general medicine, no lien
  // - 'SELFPAY' → membership / direct pay
  workflowType String    @default("MVA")  // MVA | GM | SELFPAY | NURSING_HOME

  isActive    Boolean   @default(true)

  // Order for UI display
  sortOrder   Int       @default(0)

  // Many-to-many: doctors assigned to this specialty
  doctorAssignments DoctorSpecialtyAssignment[]

  // Phoenix 2026-06-06: cases con esta specialty
  cases             Case[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([isActive])
  @@index([workflowType])
  @@map("specialty_catalog")
}

// ─── Service Codes Catalog (B.33) — CPT / HCPCS / Custom ─────────
//
// Master data de todos los códigos facturables. Consumido en B.21 (CPT
// + Firma del doctor) y B.26 (HCFA generation por Brunella).
// Versionado por año fiscal — fee_schedule cambia cada Enero.

enum ServiceType {
  CPT          // Códigos AMA · cambian anualmente
  HCPCS        // CMS Level II · drugs/DME · gratis
  CUSTOM_PM    // Internos con prefijo PM-* · no van a aseguradora
}

enum ServiceCategory {
  EM                    // Evaluation & Management (99213, 99214, etc.)
  CHIROPRACTIC          // 98941, 98942
  PHYSICAL_THERAPY      // 97110, 97140
  IMAGING               // 70010-79999
  INJECTIONS            // 20552, 64483, 64633
  SURGERY               // 10000-69999
  DME                   // Durable Medical Equipment
  DRUGS                 // J-codes
  LAB                   // Laboratorio
  REPORTS               // Narrativas legales, depo prep
  CUSTOM                // PM- internos
  OTHER
}

model ServiceCode {
  id              String          @id @default(cuid())

  code            String                       // "98941", "J3301", "PM-DIRECT"
  type            ServiceType
  shortDescription String                       // Display name corto
  longDescription  String?         @db.Text     // Full AMA description

  category        ServiceCategory

  // Fee schedule actual (Phase 1A: un solo fee per code · Phase 2: tabla historical)
  currentFee      Decimal         @db.Decimal(10, 2)
  fiscalYear      Int             @default(2026)

  // Modificadores CPT permitidos (e.g. "-25", "-59")
  modifiersAllowed String[]       @default([])

  // Notas de bundling (códigos que NO pueden facturarse juntos)
  bundlingNotes   String?         @db.Text

  // Metadata
  isActive        Boolean         @default(true)
  isInternalOnly  Boolean         @default(false)  // True para CUSTOM_PM
  sortOrder       Int             @default(0)
  notes           String?         @db.Text

  // Sugerido por especialidades (links a SpecialtyCatalog vía SpecialtyCatalog.cptSuggested array)
  // No FK directo porque ya se almacena en SpecialtyCatalog.cptSuggested[] como strings.

  favorites       UserServiceFavorite[]
  visitAssignments VisitServiceCode[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@unique([code, fiscalYear])
  @@index([type])
  @@index([category])
  @@index([isActive])
  @@map("service_codes")
}

model UserServiceFavorite {
  id            String      @id @default(cuid())
  userId        String      // Sin FK a User Phase 1A (no auth todavía) · Phase 1B FK real
  serviceCodeId String
  serviceCode   ServiceCode @relation(fields: [serviceCodeId], references: [id], onDelete: Cascade)

  usageCount    Int         @default(0)
  lastUsedAt    DateTime?

  createdAt     DateTime    @default(now())

  @@unique([userId, serviceCodeId])
  @@index([userId])
  @@index([userId, usageCount])
  @@map("user_service_favorites")
}

// ─── Phoenix Cases (B.1-B.4 Front Office + flujo completo) ──────────
//
// El Case es el contenedor principal del workflow PI. Orquesta:
// - 1 Patient (datos personales · puede tener múltiples Cases si hay
//   varios accidentes en distintos momentos)
// - 1 Bufete (FIRM) + 1 Attorney específico (INDEPENDENT del firm)
// - 1 Insurance primaria (PIP usualmente) + opcional secundaria (Med Pay)
// - 1 Specialty (Auto Accidents típico)
// - N Appointments
// - N CaseNotes (notas internas)
//
// Status flow: NEW_REFERRAL → INTAKE_PENDING → INTAKE_COMPLETED →
// CONFIRMED → ACTIVE → MMI → CLOSED → SETTLED → ARCHIVED.

enum CaseStatus {
  NEW_REFERRAL          // Recién creado · cita aún no confirmada
  INTAKE_PENDING        // Magic link enviado · esperando paciente complete B.5-B.9
  INTAKE_COMPLETED      // Paciente completó portal
  CONFIRMED             // Primera cita confirmada (llamada 24h antes)
  ACTIVE                // Tratamiento en curso
  MMI                   // Maximum Medical Improvement
  CLOSED                // Caso cerrado · pendiente settlement
  SETTLED               // Settlement recibido por Brunella
  ARCHIVED              // Histórico
  CANCELLED             // No prosperó · no-show inicial · otros
}

enum ReferralSource {
  PHONE_CALL            // Recepción humana en B.1
  WALK_IN               // Paciente camina sin cita
  LAW_FIRM_REFERRAL     // Bufete refiere directo
  PATIENT_REFERRAL      // Paciente existente refiere
  WEB_FORM              // Form público
  AI_AGENT              // Phase 3+ Vapi/Retell
  OTHER
}

enum CaseTypeWorkflow {
  MVA                   // Motor Vehicle Accident — PI con lien
  GENERAL               // Medicina general (no lien)
  WORKERS_COMP          // Workers' compensation
  NURSING_HOME          // Visitas domiciliarias
}

model Case {
  id                String              @id @default(cuid())
  caseCode          String              @unique  // "MVA-2962" auto-generado

  // Patient (existing Patient model · puede tener varios Cases)
  patientId         String
  patient           Patient             @relation("PatientCases", fields: [patientId], references: [id])

  // Workflow type + Specialty
  caseType          CaseTypeWorkflow    @default(MVA)
  specialtyId       String?
  specialty         SpecialtyCatalog?   @relation(fields: [specialtyId], references: [id])

  // Legal: firm + attorney específico
  lawFirmId         String?
  lawFirm           Lawyer?             @relation("CaseLawFirm", fields: [lawFirmId], references: [id])
  attorneyId        String?
  attorney          Lawyer?             @relation("CaseAttorney", fields: [attorneyId], references: [id])

  // Insurance — primary (PIP) + optional secondary (Med Pay)
  primaryInsuranceId    String?
  primaryInsurance      InsuranceCarrier? @relation("CasePrimaryInsurance", fields: [primaryInsuranceId], references: [id])
  primaryPolicyNumber   String?
  secondaryInsuranceId  String?
  secondaryInsurance    InsuranceCarrier? @relation("CaseSecondaryInsurance", fields: [secondaryInsuranceId], references: [id])
  secondaryPolicyNumber String?

  // Accident details (Phoenix prefiere acá vs Patient.accidentDate legacy)
  accidentDate      DateTime?
  accidentType      AccidentType?
  accidentLocation  String?
  accidentNotes     String?             @db.Text

  // Status + flow tracking
  status            CaseStatus          @default(NEW_REFERRAL)

  // Intake tracking (B.3 → B.5-B.9 portal)
  intakeFormSentAt        DateTime?
  intakeFormSentVia       String?       // "SMS" | "EMAIL"
  intakeFormCompletedAt   DateTime?
  // Token único para el magic link del portal del paciente (B.5-B.9)
  // Phase 1A: visible en respuesta de send-portal-link para testing local
  // Phase 2: hash almacenado + Supabase Auth magic links después de BAA
  portalToken             String?       @unique

  pipVerifiedAt           DateTime?
  pipVerifiedById         String?       // userId Edson

  // Confirmation tracking (24h antes de primera cita)
  firstAppointmentConfirmedAt DateTime?
  firstAppointmentConfirmedById String?

  // Creation context
  source            ReferralSource      @default(PHONE_CALL)
  createdByUserId   String?             // FK opcional (Phase 1A user stub)

  // Appointments, notas y firmas del lien
  appointments      Appointment[]       @relation("CaseAppointments")
  notes             CaseNote[]
  lienSignatures    LienSignature[]
  intakeSubmission  IntakeSubmission?   @relation("CaseIntakeSubmission")

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  @@index([caseCode])
  @@index([status])
  @@index([lawFirmId])
  @@index([primaryInsuranceId])
  @@index([patientId])
  @@index([source])
  @@index([createdAt])
  @@map("cases")
}

// Historial médico + preferencias capturadas en el portal B.5-B.9
// Phase 1A: almacenamiento en claro · Phase 2: encriptar PHI tras BAA Supabase
model IntakeSubmission {
  id                  String   @id @default(cuid())
  caseId              String   @unique
  case                Case     @relation("CaseIntakeSubmission", fields: [caseId], references: [id])

  // Step 5 — Historial médico (B.7)
  healthStatus        String?
  hasMedications      Boolean  @default(false)
  medications         String?  @db.Text
  hasAllergies        Boolean  @default(false)
  allergies           String?  @db.Text
  hasPreviousInjuries Boolean  @default(false)
  previousInjuries    String?  @db.Text

  // Step 6 — Fotos ID
  takePhotosAtClinic  Boolean  @default(false)

  // Idioma elegido en el wizard
  language            String   @default("es")

  submittedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("intake_submissions")
}

model CaseNote {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  content     String   @db.Text
  isPrivate   Boolean  @default(true)  // Privada (Front Office/Edson) vs compartida (Doctor también ve)

  authorUserId String?               // userId del que escribió la nota
  authorName   String                // Snapshot del nombre del autor (legible en historial)

  createdAt   DateTime @default(now())

  @@index([caseId])
  @@index([authorUserId])
  @@map("case_notes")
}

// ─── Insurance Catalog (B.32) ─────────────────────────────────────
//
// Master data de aseguradoras donde Brunella manda HCFA y Edson verifica
// cobertura PIP. Consumido en B.2 (Recepción autocomplete), B.12 (Edson
// pre-visita), B.26 (Brunella HCFA submission).
//
// PIP (Personal Injury Protection) — coverage del seguro del paciente para
// MVA. Med Pay — coverage adicional. Health — seguro principal del paciente.

enum InsuranceType {
  PIP      // Personal Injury Protection (Utah no-fault state) — primario para MVA
  MED_PAY  // Medical Payments — adicional, complementario
  HEALTH   // Health insurance (BCBS, UnitedHealth, etc.)
  WORKERS  // Workers' compensation
  OTHER
}

enum HcfaChannel {
  EMAIL    // Submit via email attachment
  FAX      // Traditional fax
  PORTAL   // Carrier's online portal
  PAPER    // Snail mail
  EDI      // Electronic Data Interchange (preferred for high-volume)
}

enum ResponseSpeed {
  FAST       // < 15 días
  AVERAGE    // 15-30 días
  SLOW       // > 30 días (warn badge)
  UNKNOWN    // sin data
}

model InsuranceCarrier {
  id              String        @id @default(cuid())

  name            String        @unique  // "GEICO", "State Farm", "Progressive"
  legalName       String?                  // "Government Employees Insurance"
  shortCode       String                   // "G", "SF", "PR" (max 4 chars para avatar)
  color           String        @default("#0EA5E9") // hex para avatar bg

  type            InsuranceType

  // Claims contact
  claimsPhone     String?
  claimsEmail     String?
  claimsFax       String?
  claimsAddress   String?       @db.Text
  portalUrl       String?       // URL si tiene portal

  // HCFA submission preferences
  hcfaChannel     HcfaChannel   @default(EMAIL)
  preauthRequired Boolean       @default(false)

  // Métricas (manual override Phase 1A · auto-computed Phase 2+)
  avgResponseDays Int?
  responseSpeed   ResponseSpeed @default(UNKNOWN)

  // Internal notes (Edson/Brunella privadas)
  notes           String?       @db.Text

  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)

  // Phoenix 2026-06-06: relaciones inversas a Case
  casesAsPrimary    Case[]      @relation("CasePrimaryInsurance")
  casesAsSecondary  Case[]      @relation("CaseSecondaryInsurance")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([type])
  @@index([isActive])
  @@index([responseSpeed])
  @@map("insurance_carriers")
}

// Junction table: many-to-many entre DoctorCredentials y SpecialtyCatalog.
// Un doctor puede pertenecer a varias especialidades (e.g. Auto Accidents + Pain Management).
// Una especialidad tiene varios doctores.
model DoctorSpecialtyAssignment {
  id                  String              @id @default(cuid())
  doctorCredentialsId String
  doctorCredentials   DoctorCredentials   @relation(fields: [doctorCredentialsId], references: [id], onDelete: Cascade)
  specialtyId         String
  specialty           SpecialtyCatalog    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  // Una de las especialidades del doctor debe ser primary (la principal)
  isPrimary           Boolean             @default(false)

  createdAt           DateTime            @default(now())

  @@unique([doctorCredentialsId, specialtyId])
  @@index([specialtyId])
  @@index([doctorCredentialsId])
  @@map("doctor_specialty_assignments")
}

// ─── B.22 — Lien Signatures ──────────────────────────────────────────
//
// Firma digital del lien médico. Append-only — NUNCA se actualiza ni borra.
// Cada parte (paciente, doctor, abogado, clínica) firma por separado.
// La tabla espeja la migración 20260608050000_lien_signatures.sql.

enum LienSignerType {
  PATIENT
  ATTORNEY
  DOCTOR
  CLINIC

  @@map("lien_signer_type")
}

/// Firma digital del lien médico.
/// Append-only — no UPDATE, no DELETE. Legalmente vinculante.
model LienSignature {
  id           String          @id @default(cuid())
  caseId       String
  case         Case            @relation(fields: [caseId], references: [id])

  signerType   LienSignerType
  signerName   String
  signerEmail  String?

  signatureSvg String?         @db.Text  // base64 PNG o SVG path data

  signedAt     DateTime        @default(now())

  // Audit trail
  ipAddress    String?
  userAgent    String?
  sessionToken String?

  createdAt    DateTime        @default(now())

  @@index([caseId])
  @@index([signerType])
  @@map("lien_signatures")
}

// ─── Drug catalog ────────────────────────────────────────────────────────────

model Drug {
  id       Int     @id @default(autoincrement())
  name     String
  generic  String
  schedule String? // 'II' | 'III' | 'IV' | 'V' | null
  category String  // 'NSAID' | 'RELAXANT' | 'OPIOID' | 'NEURO' | 'TOPICAL' | 'STEROID' | 'OTHER'

  @@index([category])
  @@index([generic])
  @@map("drugs")
}

model DrugInteraction {
  id           Int    @id @default(autoincrement())
  drug         String // generic name
  interactsWith String
  warning      String @db.Text

  @@index([drug])
  @@map("drug_interactions")
}

// ─── Lab / Imaging catalog ───────────────────────────────────────────────────

model LabCatalog {
  id       Int     @id @default(autoincrement())
  code     String  @unique
  name     String
  loinc    String?
  category String  // 'IMAGING' | 'LABORATORY' | 'CARDIOLOGY'

  @@index([category])
  @@map("lab_catalog")
}
