{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ],
      "env": [
        "NODE_ENV",
        "DATABASE_URL",
        "DIRECT_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "RESEND_API_KEY",
        "AI_PROVIDER",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "CULQI_PUBLIC_KEY",
        "CULQI_PRIVATE_KEY",
        "SUNAT_OSE_PROVIDER_URL",
        "SUNAT_OSE_USER",
        "SUNAT_OSE_PASSWORD",
        "SUNAT_RUC",
        "WHATSAPP_API_TOKEN",
        "WHATSAPP_PHONE_ID",
        "VAPID_PUBLIC_KEY",
        "VAPID_PRIVATE_KEY"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    }
  }
}