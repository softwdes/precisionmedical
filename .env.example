# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Pagos / SUNAT ─────────────────────────────────────
CULQI_PUBLIC_KEY=
CULQI_PRIVATE_KEY=
SUNAT_OSE_PROVIDER_URL=
SUNAT_OSE_USER=
SUNAT_OSE_PASSWORD=
SUNAT_RUC=

# ─── WhatsApp ──────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# ─── Push ──────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Sentry (observabilidad) ───────────────────────────
# DSN del proyecto Sentry de ESTA app (web y timeclock usan proyectos distintos).
# Si se deja vacío, Sentry queda inactivo (no envía nada).
NEXT_PUBLIC_SENTRY_DSN=
# Org y proyecto — usados solo en build para subir source maps.
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token para subir source maps. SOLO en Vercel/CI, nunca commitear.
SENTRY_AUTH_TOKEN=
# Token de LECTURA (scopes org:read, project:read, event:read) para que admin
# muestre métricas de Sentry en Agentes IA. Server-side, NO NEXT_PUBLIC.
SENTRY_API_TOKEN=
