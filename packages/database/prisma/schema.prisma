// =====================================================
// LM Super Admin · Prisma Schema (Reference)
// Precision Medical
// =====================================================
//
// This is the canonical Prisma schema. Use this as the
// reference for your schema.prisma file.
//
// Models are grouped by domain. Phase 0 is the minimum
// to get authentication working. Subsequent phases add
// more models as documented in DATA_MODEL.md.
// =====================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// 1. IDENTITY
// =====================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  
  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?
  
  role            UserRole
  status          UserStatus @default(ACTIVE)
  
  preferredLocale Locale     @default(es)
  preferredTheme  Theme      @default(dark)
  
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?
  
  employee        Employee?
  lawyer          Lawyer?
  provider        Provider?
  
  lastLoginAt     DateTime?
  lastLoginIp     String?
  
  sessions        Session[]
  notifications   Notification[]
  agentActions    AgentAction[]  @relation("ReviewedBy")
  auditLogs       AuditLog[]     @relation("ActorUser")

  // Phoenix 2026-06-05: relations a clinical catalogs (Templates + Diagnoses)
  createdTemplates    Template[]              @relation("TemplateCreatedBy")
  templateFavorites   TemplateFavorite[]      @relation("TemplateFavorites")
  diagnosisFavorites  UserDiagnosisFavorite[] @relation("DiagnosisFavorites")

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CONTADOR
  EMPLOYEE
  LAWYER
  PROVIDER
  AUDITOR_AI
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Locale {
  es
  en
}

enum Theme {
  light
  dark
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ipAddress String?
  userAgent String?
  device    String?
  
  expiresAt DateTime
  revokedAt DateTime?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// =====================================================
// 2. WORKFORCE
// =====================================================

model Country {
  id        String     @id @default(cuid())
  code      String     @unique  // "US", "BO", "PE"
  name      String
  currency  Currency
  
  employees Employee[]
  wallets   Wallet[]
  
  @@map("countries")
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  
  employees   Employee[]
  
  @@map("departments")
}

model Employee {
  id              String          @id @default(cuid())
  userId          String?         @unique
  user            User?           @relation(fields: [userId], references: [id])
  
  employeeCode    String          @unique
  externalId      String?         // ID from external attendance DB
  
  firstName       String
  lastName        String
  email           String
  phone           String?
  photoUrl        String?
  
  countryId       String
  country         Country         @relation(fields: [countryId], references: [id])
  city            String?
  
  type            EmploymentType
  startDate       DateTime
  endDate         DateTime?
  
  departmentId    String
  department      Department      @relation(fields: [departmentId], references: [id])
  position        String
  
  supervisorId    String?
  supervisor      Employee?       @relation("Supervision", fields: [supervisorId], references: [id])
  reports         Employee[]      @relation("Supervision")
  
  baseSalary      Decimal?        @db.Decimal(12, 2)
  baseCurrency    Currency
  hourlyRate      Decimal?        @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  bankAccount     String?         // encrypted at app level
  bankQrUrl       String?
  
  status          EmployeeStatus  @default(ACTIVE)
  
  payments        Payment[]
  tasks           Task[]          @relation("AssignedTo")
  reviewedTasks   Task[]          @relation("Supervisor")
  attendanceSync  AttendanceSync[]
  metricSnapshots MetricSnapshot[]
  documents       EmployeeDocument[]

  // Phoenix 2026-06-05: credentials clínicas (NPI/DEA/license) si position=DOCTOR.
  // Tabla separada para no inflar Employee con NULLs para empleados no-doctores.
  doctorCredentials DoctorCredentials?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([countryId])
  @@index([type])
  @@index([status])
  @@index([departmentId])
  @@index([externalId])
  @@map("employees")
}

enum EmploymentType {
  FULL_TIME
  EXTERNAL
  CONTRACTOR
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  ZELLE
  WIRE
  OTHER
}

model EmployeeDocument {
  id         String       @id @default(cuid())
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  type       DocumentType
  name       String
  fileUrl    String
  uploadedBy String
  
  createdAt  DateTime     @default(now())
  
  @@map("employee_documents")
}

enum DocumentType {
  CONTRACT
  ID
  NDA
  TAX_FORM
  OTHER
}

model AttendanceSync {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  
  date       DateTime  @db.Date
  
  clockIn    DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  clockOut   DateTime?
  
  totalHours Decimal?  @db.Decimal(5, 2)
  isLate     Boolean   @default(false)
  isAbsent   Boolean   @default(false)
  
  externalId String?
  syncedAt   DateTime  @default(now())
  
  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance_sync")
}

model Task {
  id              String       @id @default(cuid())
  
  title           String
  description     String?
  
  assigneeId      String
  assignee        Employee     @relation("AssignedTo", fields: [assigneeId], references: [id])
  
  supervisorId    String?
  supervisor      Employee?    @relation("Supervisor", fields: [supervisorId], references: [id])
  
  status          TaskStatus   @default(ASSIGNED)
  priority        TaskPriority @default(NORMAL)
  
  assignedDate    DateTime     @default(now())
  dueDate         DateTime
  completedDate   DateTime?
  
  qualityRating   Int?
  qualityFeedback String?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  REVIEWED
  REJECTED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model MetricSnapshot {
  id                String   @id @default(cuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  
  date              DateTime @db.Date
  
  punctualityScore  Decimal  @db.Decimal(5, 2)
  taskOnTimeScore   Decimal  @db.Decimal(5, 2)
  productivityScore Decimal  @db.Decimal(5, 2)
  qualityScore      Decimal  @db.Decimal(5, 2)
  attendanceScore   Decimal  @db.Decimal(5, 2)
  
  globalScore       Decimal  @db.Decimal(5, 2)
  grade             Grade
  
  computedAt        DateTime @default(now())
  
  @@unique([employeeId, date])
  @@index([date])
  @@index([globalScore])
  @@map("metric_snapshots")
}

enum Grade {
  A_PLUS
  A
  B
  C
  D
}

// =====================================================
// 3. FINANCE
// =====================================================

enum Currency {
  USD
  BOB
  PEN
}

model Wallet {
  id               String        @id @default(cuid())
  currency         Currency
  countryId        String
  country          Country       @relation(fields: [countryId], references: [id])
  
  name             String
  balance          Decimal       @db.Decimal(15, 2) @default(0)
  
  lastReconciledAt DateTime?
  lastReconciledBy String?
  lastMovementAt   DateTime?
  isActive         Boolean       @default(true)

  fxFromOps        FxOperation[] @relation("FromWallet")
  fxToOps          FxOperation[] @relation("ToWallet")
  payments         Payment[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  @@unique([currency, countryId])
  @@map("wallets")
}

model FxOperation {
  id            String   @id @default(cuid())
  
  fromWalletId  String
  fromWallet    Wallet   @relation("FromWallet", fields: [fromWalletId], references: [id])
  
  toWalletId    String
  toWallet      Wallet   @relation("ToWallet", fields: [toWalletId], references: [id])
  
  amountFrom    Decimal  @db.Decimal(15, 2)
  amountTo      Decimal  @db.Decimal(15, 2)
  rate          Decimal  @db.Decimal(12, 6)
  fee           Decimal  @db.Decimal(10, 2) @default(0)
  
  exchangeHouse String?
  receiptUrl    String?
  notes         String?
  
  performedById String
  performedAt   DateTime @default(now())
  
  reversedById  String?  // Append-only: edits create reversals
  
  createdAt     DateTime @default(now())
  
  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([performedAt])
  @@map("fx_operations")
}

model Payment {
  id              String        @id @default(cuid())
  
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id])
  
  walletId        String
  wallet          Wallet        @relation(fields: [walletId], references: [id])
  
  period          String
  
  amountLocal     Decimal       @db.Decimal(12, 2)
  currencyLocal   Currency
  amountUsdEquiv  Decimal       @db.Decimal(12, 2)
  rateApplied     Decimal       @db.Decimal(12, 6)
  
  status          PaymentStatus @default(PENDING)
  
  scheduledDate   DateTime
  paidDate        DateTime?
  
  proofUrl        String?
  notes           String?

  baseSalary      Decimal?      @db.Decimal(12, 2) @map("base_salary")
  bonusAmount     Decimal?      @db.Decimal(12, 2) @map("bonus_amount")
  bonusReason     String?                           @map("bonus_reason")

  reversedById    String?  // Append-only
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([employeeId])
  @@index([period])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SCHEDULED
  PAID
  PARTIAL
  CANCELLED
  REVERSED
}

model CashBox {
  id                  String            @id @default(cuid())
  name                String            @unique
  clinicId            String?
  
  currency            Currency          @default(USD)
  balance             Decimal           @db.Decimal(12, 2) @default(0)
  lowBalanceThreshold Decimal           @db.Decimal(12, 2) @default(100)
  
  responsibleUserId   String?
  
  transactions        CashTransaction[]
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  @@map("cash_boxes")
}

model CashTransaction {
  id            String              @id @default(cuid())
  cashBoxId     String
  cashBox       CashBox             @relation(fields: [cashBoxId], references: [id])
  
  type          CashTransactionType
  amount        Decimal             @db.Decimal(12, 2)
  
  category      CashCategory
  description   String
  
  receiptUrl    String?

  performedById String
  performedAt   DateTime            @default(now())

  reversedById  String?  // Append-only

  // Fase 4 — Caja Chica ↔ Wallet: si un DEPÓSITO se financió desde una
  // cartera, aquí guardamos cuál. Ese monto cuenta como salida de esa wallet
  // (en su misma moneda). Opcional: depósitos sin origen no afectan wallets.
  sourceWalletId String?

  createdAt     DateTime            @default(now())

  @@index([cashBoxId])
  @@index([performedAt])
  @@index([category])
  @@index([sourceWalletId])
  @@map("cash_transactions")
}

enum CashTransactionType {
  DEPOSIT
  EXPENSE
}

enum CashCategory {
  MEDICAL_SUPPLIES
  TRANSPORT
  FOOD
  OFFICE
  UTILITIES
  MAINTENANCE
  CALACOTO
  RECORDINGS
  VIATICOS
  OTHER
}

// =====================================================
// 4. EXTERNAL RELATIONS
// =====================================================

model Lawyer {
  id               String            @id @default(cuid())
  userId           String?           @unique
  user             User?             @relation(fields: [userId], references: [id])

  entityType       LawyerEntityType

  firstName        String?
  lastName         String?
  firmName         String?

  parentFirmId     String?
  parentFirm       Lawyer?           @relation("FirmMembers", fields: [parentFirmId], references: [id])
  members          Lawyer[]          @relation("FirmMembers")

  email            String            @unique
  phone            String?
  address          String?

  // Phoenix 2026-06-06 (B.30/B.31): campos extra para catálogo de Bufetes
  city             String?           // Provo, West Valley, etc.
  state            String?           // ISO state code (UT)
  memberRole       LawyerMemberRole? // solo aplica si parentFirmId is set
  notes            String?           // notas internas de Edson (privadas)
  paymentSpeed     PaymentSpeed?     // marca rápido/lento para badge en B.30
  caseflowFlags    String[]          @default([]) // PIP-COVERED, MED-PAY, etc.

  status           ExternalStatus    @default(ACTIVE)

  commissionConfig CommissionConfig?

  referrals        Patient[]         @relation("LawyerReferrer")
  commissions      Commission[]      @relation("LawyerCommission")

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([entityType])
  @@index([parentFirmId])
  @@index([city])
  @@map("lawyers")
}

// Phoenix 2026-06-06: rol del member dentro del bufete (B.31)
enum LawyerMemberRole {
  ATTORNEY       // Abogado titular
  CASE_MANAGER   // Manejador de casos · contacto operativo
  PARALEGAL      // Asistente legal
  OTHER
}

// Phoenix 2026-06-06: badge de velocidad de pago para listado B.30
enum PaymentSpeed {
  FAST       // < 90 días promedio
  AVERAGE    // 90-150 días
  SLOW       // > 150 días (warn badge)
  UNKNOWN    // sin data aún
}

enum LawyerEntityType {
  FIRM
  INDEPENDENT
  FIRM_MEMBER
}

model Provider {
  id             String          @id @default(cuid())
  userId         String?         @unique
  user           User?           @relation(fields: [userId], references: [id])
  
  firstName      String
  lastName       String
  
  email          String          @unique
  phone          String?
  
  specialty      Specialty
  licenseNumber  String?
  
  status         ExternalStatus  @default(ACTIVE)
  
  serviceTariffs ServiceTariff[]
  
  referrals      Patient[]       @relation("ProviderReferrer")
  commissions    Commission[]    @relation("ProviderCommission")
  appointments   Appointment[]
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  
  @@map("providers")
}

enum ExternalStatus {
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
  TERMINATED
}

enum Specialty {
  RADIOLOGY
  NEUROLOGY
  ORTHOPEDICS
  PHYSICAL_THERAPY
  CHIROPRACTIC
  PAIN_MANAGEMENT
  PSYCHOLOGY
  GENERAL
  OTHER
}

model ServiceTariff {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  
  serviceName String
  amount      Decimal  @db.Decimal(10, 2)
  currency    Currency @default(USD)
  
  @@map("service_tariffs")
}

model Patient {
  id                 String          @id @default(cuid())
  
  patientCode        String          @unique
  
  firstName          String
  lastName           String
  email              String?
  phone              String?
  dateOfBirth        DateTime?
  
  accidentDate       DateTime?
  accidentType       AccidentType?
  insuranceCarrier   String?
  policyNumber       String?
  
  lawyerReferrerId   String?
  lawyerReferrer     Lawyer?         @relation("LawyerReferrer", fields: [lawyerReferrerId], references: [id])
  
  providerReferrerId String?
  providerReferrer   Provider?       @relation("ProviderReferrer", fields: [providerReferrerId], references: [id])
  
  status             PatientStatus   @default(NEW)
  
  appointments       Appointment[]
  commissions        Commission[]
  
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  
  @@index([lawyerReferrerId])
  @@index([providerReferrerId])
  @@index([status])
  @@map("patients")
}

enum PatientStatus {
  NEW
  ACTIVE
  COMPLETED
  DISCHARGED
  INACTIVE
}

enum AccidentType {
  AUTO
  MOTORCYCLE
  PEDESTRIAN
  WORKPLACE
  OTHER
}

model Clinic {
  id           String        @id @default(cuid())
  name         String        @unique
  address      String?
  phone        String?
  
  appointments Appointment[]
  
  @@map("clinics")
}

model Appointment {
  id              String            @id @default(cuid())
  
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  
  clinicId        String
  clinic          Clinic            @relation(fields: [clinicId], references: [id])
  
  providerId      String?
  provider        Provider?         @relation(fields: [providerId], references: [id])
  
  scheduledFor    DateTime
  durationMinutes Int               @default(30)
  
  type            AppointmentType
  status          AppointmentStatus @default(SCHEDULED)
  
  notes           String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([patientId])
  @@index([clinicId])
  @@index([scheduledFor])
  @@index([status])
  @@map("appointments")
}

enum AppointmentType {
  AUTO_ACCIDENT
  FAMILY_PRACTICE
  URGENT_CARE
  FOLLOW_UP
  CONSULTATION
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING
}

// =====================================================
// 5. COMMISSIONS
// =====================================================

model CommissionConfig {
  id            String           @id @default(cuid())
  lawyerId      String           @unique
  lawyer        Lawyer           @relation(fields: [lawyerId], references: [id])
  
  scheme        CommissionScheme
  
  flatAmount    Decimal?         @db.Decimal(10, 2)
  percentage    Decimal?         @db.Decimal(5, 2)
  tiers         Json?
  hybridConfig  Json?
  
  effectiveFrom DateTime
  effectiveTo   DateTime?
  
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  @@map("commission_configs")
}

enum CommissionScheme {
  FLAT_PER_REFERRAL
  PERCENTAGE_OF_BILLING
  VOLUME_TIER
  HYBRID
}

model Commission {
  id           String           @id @default(cuid())
  
  lawyerId     String?
  lawyer       Lawyer?          @relation("LawyerCommission", fields: [lawyerId], references: [id])
  
  providerId   String?
  provider     Provider?        @relation("ProviderCommission", fields: [providerId], references: [id])
  
  patientId    String
  patient      Patient          @relation(fields: [patientId], references: [id])
  
  amount       Decimal          @db.Decimal(12, 2)
  currency     Currency         @default(USD)
  
  status       CommissionStatus @default(EARNED)
  earnedAt     DateTime         @default(now())
  paidAt       DateTime?
  paidProofUrl String?
  
  reversedById String?  // Append-only
  
  notes        String?
  
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  
  @@index([lawyerId])
  @@index([providerId])
  @@index([status])
  @@index([earnedAt])
  @@map("commissions")
}

enum CommissionStatus {
  EARNED
  APPROVED
  PAID
  CANCELLED
  REVERSED
}

// =====================================================
// 6. AI AGENTS
// =====================================================

model Agent {
  id                 String         @id @default(cuid())
  
  name               String         @unique
  type               AgentType
  description        String
  
  status             AgentStatus    @default(IDLE)
  mode               AgentMode      @default(MANUAL)
  
  schedule           String?
  
  permissions        String[]
  budgetMonthlyUsd   Decimal        @db.Decimal(10, 2) @default(100)
  
  llmProvider        LlmProvider    @default(ANTHROPIC)
  llmModel           String         @default("claude-3-5-sonnet")
  
  voiceEnabled       Boolean        @default(false)
  voiceProvider      VoiceProvider?
  voiceConfig        Json?
  
  totalActions       Int            @default(0)
  totalTokensUsed    BigInt         @default(0)
  totalCostUsd       Decimal        @db.Decimal(10, 4) @default(0)
  
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  
  actions            AgentAction[]
  
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  @@map("agents")
}

enum AgentType {
  CONVERSATIONAL
  AUDITOR
  METRICS
  FX_WATCHER
  REFERRAL_OPTIMIZER
  ORCHESTRATOR
}

enum AgentStatus {
  IDLE
  RUNNING
  PAUSED
  ERROR
}

enum AgentMode {
  MANUAL
  APPROVAL
  AUTONOMOUS
}

enum LlmProvider {
  ANTHROPIC
  OPENAI
  CUSTOM
}

enum VoiceProvider {
  WEB_SPEECH
  ELEVENLABS
  OPENAI_TTS
}

model AgentAction {
  id            String          @id @default(cuid())
  agentId       String
  agent         Agent           @relation(fields: [agentId], references: [id])
  
  type          AgentActionType
  severity      ActionSeverity  @default(INFO)
  status        ActionStatus    @default(PENDING_REVIEW)
  
  payload       Json
  summary       String
  
  appliedAt     DateTime?
  appliedResult Json?
  
  reviewedById  String?
  reviewer      User?           @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt    DateTime?
  reviewNotes   String?
  
  tokensUsed    Int             @default(0)
  costUsd       Decimal         @db.Decimal(10, 6) @default(0)
  
  createdAt     DateTime        @default(now())
  
  @@index([agentId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("agent_actions")
}

enum AgentActionType {
  DETECTION
  RECOMMENDATION
  AUTO_FIX
  CONVERSATION
  TOOL_CALL
}

enum ActionSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ActionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  APPLIED
  FAILED
  AUTO_APPLIED
}

model AgentConversation {
  id        String   @id @default(cuid())
  agentId   String
  userId    String
  
  messages  Json
  
  startedAt DateTime @default(now())
  endedAt   DateTime?
  
  @@index([userId])
  @@index([startedAt])
  @@map("agent_conversations")
}

// =====================================================
// 6B. FREELANCERS
// =====================================================

enum FreelancerModalidad {
  POR_HORA
  POR_SERVICIO
  CONTRATISTA
}

enum FreelancerStatus {
  ACTIVE
  INACTIVE
}

enum FreelancerPaymentStatus {
  PENDING
  PAID
  CANCELLED
  REVERSED
}

model Freelancer {
  id         String             @id @default(cuid())
  nombre     String
  email      String?
  phone      String?
  pais       String
  modalidad  FreelancerModalidad
  tarifaBase Decimal?           @db.Decimal(10, 2)
  moneda     Currency           @default(USD)
  status     FreelancerStatus   @default(ACTIVE)
  notas      String?
  bankQrUrl  String?

  payments   FreelancerPayment[]

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  deletedAt  DateTime?

  @@index([status])
  @@index([modalidad])
  @@map("freelancers")
}

model FreelancerPayment {
  id            String             @id @default(cuid())
  freelancerId  String
  freelancer    Freelancer         @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  descripcion   String
  modalidad     FreelancerModalidad
  horas         Decimal?           @db.Decimal(8, 2)
  tarifaHora    Decimal?           @db.Decimal(10, 2)
  monto         Decimal            @db.Decimal(12, 2)
  moneda        Currency           @default(USD)

  status        FreelancerPaymentStatus @default(PENDING)
  fechaServicio DateTime           @db.Date
  scheduledDate DateTime?          @db.Date
  fechaPago     DateTime?          @db.Date
  paidDate      DateTime?          @db.Date

  bonusAmount   Decimal?           @db.Decimal(12, 2)
  bonusReason   String?

  reversedById  String?            // Append-only — points to the reversal pair

  notas         String?

  createdAt     DateTime           @default(now())

  @@index([freelancerId])
  @@index([fechaPago])
  @@index([status])
  @@index([status, scheduledDate])
  @@map("freelancer_payments")
}

// =====================================================
// 7. SYSTEM
// =====================================================

model AuditLog {
  id              String    @id @default(cuid())

  // Phoenix 2026-06-05: actorType hook obligatorio para AI Receptionist Phase 3+.
  // Hoy todos los registros son HUMAN_USER; el schema lo soporta para que en
  // Phase 3 podamos auditar acciones del AI agent sin migration breaking.
  actorType       ActorType @default(HUMAN_USER)

  actorUserId     String?
  actor           User?     @relation("ActorUser", fields: [actorUserId], references: [id])
  actorRole       UserRole?

  // Phoenix 2026-06-05: idempotency-key opcional para reintentos del AI agent.
  // AI puede reintentar la misma llamada si pierde conexión; este key previene duplicados.
  idempotencyKey  String?

  action          String
  entityType      String?
  entityId        String?

  ipAddress       String?
  userAgent       String?

  before          Json?
  after           Json?
  metadata        Json?

  createdAt       DateTime  @default(now())

  @@index([actorUserId])
  @@index([actorType])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@map("audit_logs")
}

// Phoenix 2026-06-05: tipo de actor para audit log.
// HUMAN_USER = acción iniciada por usuario humano via UI.
// AI_AGENT   = acción iniciada por AI Receptionist (Phase 3+) u otros agentes AI.
// SYSTEM     = acción iniciada por cron/webhooks/scheduled tasks.
enum ActorType {
  HUMAN_USER
  AI_AGENT
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  body      String?
  
  linkUrl   String?
  
  readAt    DateTime?
  
  createdAt DateTime         @default(now())
  
  @@index([userId, readAt])
  @@map("notifications")
}

enum NotificationType {
  SYSTEM
  TASK_ASSIGNED
  PAYMENT_PROCESSED
  COMMISSION_EARNED
  PATIENT_REFERRED
  AGENT_ALERT
  PERFORMANCE_REPORT
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?

  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// =====================================================
// PHOENIX (LM v3) — Phase 0 additions · NO-PHI catalogs
// Added 2026-06-05 · Erick + Claude
// =====================================================
// These models support the clinical workflow (B.17.5-B.18, B.35)
// captured from the LM legacy. They are catalog/metadata only —
// patient data (PHI) does NOT live here. Phase 1 adds PHI tables
// (patients, cases, visits, notes) AFTER BAA Supabase signs.
// =====================================================

// ─── Doctor Credentials (clinical extension of Employee) ─────────
//
// One-to-one with Employee where Employee.position = 'DOCTOR'.
// Separate table to avoid inflating Employee with NULLable
// clinical fields for the 90% of employees who are not doctors.
// All fields are clinical credentials — NOT PHI (provider data).
model DoctorCredentials {
  id                    String     @id @default(cuid())
  employeeId            String     @unique
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // National Provider Identifier — mandatory for HCFA (CMS-1500) claim submission.
  // Source: NPPES (https://npiregistry.cms.hhs.gov). Public registry.
  npiNumber             String?    @unique

  // DEA (Drug Enforcement Administration) number — required to prescribe
  // controlled substances via DAW EPCS (B.19). Restricted access.
  deaNumber             String?    @unique

  // State medical license — required to practice. State must match
  // clinic state for non-telehealth visits.
  medicalLicenseNumber  String?
  medicalLicenseState   String?    // ISO state code (e.g. "UT")

  specialty             Specialty  // Legacy enum — backward compat. Primary specialty también va en DoctorSpecialtyAssignment.
  signatureUrl          String?    // Digital signature for SOAP notes (B.21 firma)

  isActive              Boolean    @default(true)

  // Phoenix 2026-06-06: many-to-many con SpecialtyCatalog (B.36)
  specialtyAssignments  DoctorSpecialtyAssignment[]

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([npiNumber])
  @@index([deaNumber])
  @@index([specialty])
  @@map("doctor_credentials")
}

// ─── Templates (B.17.5 / B.17.6 / B.17.7) ────────────────────────
//
// Doctor note templates captured from the LM legacy. Each template
// has sections (CC/HPI/ROS/PE/Eval/Plan/Dx) which are toggleable
// per use. Sections can contain variants (tiered options), procedural
// blocks (e.g. trigger point injection), and price references (snapshot
// at signing for closing case notes → demand letter B.28).

enum TemplateScope {
  PERSONAL  // Owned by single doctor (default for new templates)
  SHARED    // Available to all doctors across all clinics
  SPECIALTY // Available only to doctors of a specific specialty
}

enum EncounterType {
  FOLLOW_UP
  NEW_PATIENT
  RE_EVAL
  URI          // Upper Respiratory Infection
  PHYSICAL     // Annual physical
  NURSING_HOME
  CLOSING      // MMI / discharge case (with future-care prices)
  OTHER
}

enum CaseType {
  MVA      // Motor Vehicle Accident — primary at Precision Medical
  GENERAL
  NURSING_HOME
}

enum TemplateSectionKey {
  QUEJA_PRINCIPAL  // Chief Complaint
  HPI              // Historia de la Enfermedad Actual (History of Present Illness)
  ROS              // Revisión de Sistemas (Review of Systems)
  EXAMEN_FISICO    // Physical Exam
  EVALUACIONES     // Assessment (tiered + causation statement for PI)
  PLAN             // Treatment plan (with variants + procedural + prices)
  DIAGNOSTICOS     // Diagnoses (ICD-10 + SNOMED dual)
}

model Template {
  id            String          @id @default(cuid())

  title         String          // e.g. "NG-MVA F/U" (prefix=doctor, suffix=encounter type)
  description   String?         // e.g. "Motor Vehicle Accident Follow-up"

  encounterType EncounterType
  caseType      CaseType        @default(GENERAL)
  scope         TemplateScope   @default(PERSONAL)

  // For SPECIALTY scope: which specialty owns this template.
  // Null for PERSONAL/SHARED.
  // NOTE: Specialty enum exists in this schema (Provider model uses it).
  specialty     Specialty?

  createdById   String
  createdBy     User            @relation("TemplateCreatedBy", fields: [createdById], references: [id])

  sections      TemplateSection[]
  favorites     TemplateFavorite[]

  usageCount    Int             @default(0)
  isActive      Boolean         @default(true)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([scope])
  @@index([encounterType])
  @@index([caseType])
  @@index([createdById])
  @@index([specialty])
  @@map("templates")
}

model TemplateSection {
  id              String              @id @default(cuid())
  templateId      String
  template        Template            @relation(fields: [templateId], references: [id], onDelete: Cascade)

  sectionKey      TemplateSectionKey
  content         String              @db.Text  // HTML rich text with placeholders
  enabledByDefault Boolean            @default(true)

  // Tiered options inline (e.g. Evaluaciones Básica/Intermedia/Severa).
  // Doctor deletes variants that don't apply. JSON shape:
  // [{ label: string, content: string }]
  variants         Json?

  // Reusable procedural notes (e.g. trigger point injection narrative).
  // Conditionally activated by doctor. JSON shape:
  // [{ trigger: string, content: string, cpt_code: string, consent_required: boolean }]
  proceduralBlocks Json?

  // Price references for Closing Case notes. Snapshot taken at signing
  // (B.18 firma) — feeds demand letter (B.28). JSON shape:
  // [{ label: string, cpt_code: string }]
  priceReferences  Json?

  // Locked content blocks that require confirm to delete (e.g. PI causation
  // statement: "reasonable degree of medical certainty..."). JSON shape:
  // [{ content_substring: string, warning_message: string }]
  lockedBlocks     Json?

  orderIndex       Int                 @default(0)

  @@unique([templateId, sectionKey])
  @@index([templateId])
  @@map("template_sections")
}

model TemplateFavorite {
  id          String   @id @default(cuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("TemplateFavorites", fields: [userId], references: [id])

  // Personal usage tracking for autocomplete ranking
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?

  createdAt   DateTime @default(now())

  @@unique([templateId, userId])
  @@index([userId])
  @@index([userId, usageCount])
  @@map("template_favorites")
}

// ─── Diagnoses (B.35) — Dual ICD-10 + SNOMED CT ──────────────────
//
// Both code systems are FREE for clinical use in the US:
// - ICD-10-CM: published by CDC annually. ~70K codes.
//   https://www.cdc.gov/nchs/icd/icd-10-cm/files.html
// - SNOMED CT: licensed but FREE for US clinical use via NLM/UMLS.
//   ~350K concepts.
//   https://www.nlm.nih.gov/healthit/snomedct/index.html
//
// Pattern from legacy: each diagnosis row pairs an ICD-10 (for billing
// HCFA/CMS-1500) with an optional SNOMED (for clinical granularity +
// longitudinal reports). DiagnosisMapping table allows additional
// 1-to-many alternates if needed beyond the primary pair.

enum DiagnosisCategory {
  S        // Lesiones (Injuries) — S00-T98 in ICD-10
  T        // (continuation of S range)
  M        // Musculoesqueléticas / Musculoskeletal — M00-M99
  R        // Síntomas / Symptoms — R00-R99
  G        // Neurológicas / Neurological — G00-G99
  F        // Mental / Behavioral — F00-F99
  V_W      // External cause (accident) — V00-W99 (e.g. V43.52XA MVA codes)
  Z        // Factors influencing health — Z00-Z99
  OTHER
}

model Diagnosis {
  id                String                 @id @default(cuid())

  // Dual coding — primary pair
  icd10Code         String                 @unique
  icd10Description  String
  snomedCode        String?
  snomedDescription String?

  category          DiagnosisCategory
  bodySystem        String?                // e.g. "Cervical spine", "Lumbar spine", "Head"
  piRelevant        Boolean                @default(false)  // Flag for PI workflow

  // Usage tracking for autocomplete ranking
  usageCount        Int                    @default(0)
  isActive          Boolean                @default(true)

  favorites         UserDiagnosisFavorite[]
  mappings          DiagnosisMapping[]

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([icd10Code])
  @@index([snomedCode])
  @@index([category])
  @@index([piRelevant])
  @@map("diagnoses")
}

// Cross-reference for additional ICD-10 ↔ SNOMED mappings beyond the
// primary pair on Diagnosis. Useful when one ICD-10 has multiple valid
// SNOMED concepts of varying specificity.
model DiagnosisMapping {
  id              String     @id @default(cuid())
  diagnosisId     String
  diagnosis       Diagnosis  @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  alternateIcd10  String?
  alternateSnomed String?

  // EXACT (1:1), BROADER (alternate is more general),
  // NARROWER (alternate is more specific), RELATED (lateral concept)
  mappingType     String

  notes           String?    @db.Text

  @@index([diagnosisId])
  @@map("diagnosis_mappings")
}

model UserDiagnosisFavorite {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("DiagnosisFavorites", fields: [userId], references: [id])
  diagnosisId String
  diagnosis   Diagnosis @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)

  // Personal usage tracking for autocomplete ranking
  usageCount  Int       @default(0)
  lastUsedAt  DateTime?

  createdAt   DateTime  @default(now())

  @@unique([userId, diagnosisId])
  @@index([userId])
  @@index([userId, usageCount])
  @@map("user_diagnosis_favorites")
}

// ─── Specialty Catalog (B.36) ─────────────────────────────────────
//
// Source-of-truth de las líneas de servicio de la clínica.
// Reemplaza al enum legacy `Specialty` (que sigue existiendo arriba
// para compatibilidad con Provider/DoctorCredentials/Template, pero
// el CRUD opera sobre esta tabla).
//
// Mockup canónico: B.36 (Catálogo de Especialidades / Service lines).
// Mejoras vs LM legacy: color picker · CPT codes sugeridos · métricas
// agregadas · soft delete · cardinalidad muchos-a-muchos con doctores.

model SpecialtyCatalog {
  id          String    @id @default(cuid())

  name        String    @unique  // "Auto Accidents", "Pain Management", etc.
  description String?
  color       String              // hex "#F43F5E" — consumido en B.10 calendar, B.17 Mi día, B.29 dashboard
  caseType    CaseType  @default(GENERAL)

  // CPT codes sugeridos — pre-cargan en B.21 al firmar nota
  cptSuggested String[]  @default([])

  // Workflow type asociado:
  // - 'MVA' → flujo PI con lien
  // - 'GM'  → general medicine, no lien
  // - 'SELFPAY' → membership / direct pay
  workflowType String    @default("MVA")  // MVA | GM | SELFPAY | NURSING_HOME

  isActive    Boolean   @default(true)

  // Order for UI display
  sortOrder   Int       @default(0)

  // Many-to-many: doctors assigned to this specialty
  doctorAssignments DoctorSpecialtyAssignment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([isActive])
  @@index([workflowType])
  @@map("specialty_catalog")
}

// Junction table: many-to-many entre DoctorCredentials y SpecialtyCatalog.
// Un doctor puede pertenecer a varias especialidades (e.g. Auto Accidents + Pain Management).
// Una especialidad tiene varios doctores.
model DoctorSpecialtyAssignment {
  id                  String              @id @default(cuid())
  doctorCredentialsId String
  doctorCredentials   DoctorCredentials   @relation(fields: [doctorCredentialsId], references: [id], onDelete: Cascade)
  specialtyId         String
  specialty           SpecialtyCatalog    @relation(fields: [specialtyId], references: [id], onDelete: Cascade)

  // Una de las especialidades del doctor debe ser primary (la principal)
  isPrimary           Boolean             @default(false)

  createdAt           DateTime            @default(now())

  @@unique([doctorCredentialsId, specialtyId])
  @@index([specialtyId])
  @@index([doctorCredentialsId])
  @@map("doctor_specialty_assignments")
}
