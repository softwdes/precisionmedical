// =====================================================
// LM Super Admin · Prisma Schema (Reference)
// Precision Medical
// =====================================================
//
// This is the canonical Prisma schema. Use this as the
// reference for your schema.prisma file.
//
// Models are grouped by domain. Phase 0 is the minimum
// to get authentication working. Subsequent phases add
// more models as documented in DATA_MODEL.md.
// =====================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// 1. IDENTITY
// =====================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  
  firstName       String
  lastName        String
  avatarUrl       String?
  phone           String?
  
  role            UserRole
  status          UserStatus @default(ACTIVE)
  
  preferredLocale Locale     @default(es)
  preferredTheme  Theme      @default(dark)
  
  mfaEnabled      Boolean    @default(false)
  mfaSecret       String?
  
  employee        Employee?
  lawyer          Lawyer?
  provider        Provider?
  
  lastLoginAt          DateTime?
  lastLoginIp          String?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastFailedAttemptAt  DateTime?
  
  sessions        Session[]
  notifications   Notification[]
  agentActions    AgentAction[]  @relation("ReviewedBy")
  auditLogs       AuditLog[]     @relation("ActorUser")

  // Phoenix 2026-06-05: relations a clinical catalogs (Templates + Diagnoses)
  createdTemplates    Template[]              @relation("TemplateCreatedBy")
  templateFavorites   TemplateFavorite[]      @relation("TemplateFavorites")
  diagnosisFavorites  UserDiagnosisFavorite[] @relation("DiagnosisFavorites")

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CONTADOR
  EMPLOYEE
  LAWYER
  PROVIDER
  AUDITOR_AI
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Locale {
  es
  en
}

enum Theme {
  light
  dark
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  ipAddress String?
  userAgent String?
  device    String?
  
  expiresAt DateTime
  revokedAt DateTime?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// =====================================================
// 2. WORKFORCE
// =====================================================

model Country {
  id        String     @id @default(cuid())
  code      String     @unique  // "US", "BO", "PE"
  name      String
  currency  Currency
  
  employees Employee[]
  wallets   Wallet[]
  
  @@map("countries")
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  
  employees   Employee[]
  
  @@map("departments")
}

model Employee {
  id              String          @id @default(cuid())
  userId          String?         @unique
  user            User?           @relation(fields: [userId], references: [id])
  
  employeeCode    String          @unique
  externalId      String?         // ID from external attendance DB
  
  firstName       String
  lastName        String
  email           String
  phone           String?
  photoUrl        String?
  
  countryId       String
  country         Country         @relation(fields: [countryId], references: [id])
  city            String?
  
  type            EmploymentType
  startDate       DateTime
  endDate         DateTime?
  
  departmentId    String
  department      Department      @relation(fields: [departmentId], references: [id])
  position        String
  
  supervisorId    String?
  supervisor      Employee?       @relation("Supervision", fields: [supervisorId], references: [id])
  reports         Employee[]      @relation("Supervision")
  
  baseSalary      Decimal?        @db.Decimal(12, 2)
  baseCurrency    Currency
  hourlyRate      Decimal?        @db.Decimal(10, 2)
  paymentMethod   PaymentMethod?
  bankAccount     String?         // encrypted at app level
  bankQrUrl       String?
  
  status          EmployeeStatus  @default(ACTIVE)
  
  payments        Payment[]
  tasks           Task[]          @relation("AssignedTo")
  reviewedTasks   Task[]          @relation("Supervisor")
  attendanceSync  AttendanceSync[]
  metricSnapshots MetricSnapshot[]
  documents       EmployeeDocument[]

  // Phoenix 2026-06-05: credentials clínicas (NPI/DEA/license) si position=DOCTOR.
  // Tabla separada para no inflar Employee con NULLs para empleados no-doctores.
  doctorCredentials DoctorCredentials?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  @@index([countryId])
  @@index([type])
  @@index([status])
  @@index([departmentId])
  @@index([externalId])
  @@map("employees")
}

enum EmploymentType {
  FULL_TIME
  EXTERNAL
  CONTRACTOR
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  ZELLE
  WIRE
  OTHER
}

model EmployeeDocument {
  id         String       @id @default(cuid())
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  type       DocumentType
  name       String
  fileUrl    String
  uploadedBy String
  
  createdAt  DateTime     @default(now())
  
  @@map("employee_documents")
}

enum DocumentType {
  CONTRACT
  ID
  NDA
  TAX_FORM
  OTHER
}

model AttendanceSync {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  
  date       DateTime  @db.Date
  
  clockIn    DateTime?
  breakStart DateTime?
  breakEnd   DateTime?
  clockOut   DateTime?
  
  totalHours Decimal?  @db.Decimal(5, 2)
  isLate     Boolean   @default(false)
  isAbsent   Boolean   @default(false)
  
  externalId String?
  syncedAt   DateTime  @default(now())
  
  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance_sync")
}

model Task {
  id              String       @id @default(cuid())
  
  title           String
  description     String?
  
  assigneeId      String
  assignee        Employee     @relation("AssignedTo", fields: [assigneeId], references: [id])
  
  supervisorId    String?
  supervisor      Employee?    @relation("Supervisor", fields: [supervisorId], references: [id])
  
  status          TaskStatus   @default(ASSIGNED)
  priority        TaskPriority @default(NORMAL)
  
  assignedDate    DateTime     @default(now())
  dueDate         DateTime
  completedDate   DateTime?
  
  qualityRating   Int?
  qualityFeedback String?
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  REVIEWED
  REJECTED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model MetricSnapshot {
  id                String   @id @default(cuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  
  date              DateTime @db.Date
  
  punctualityScore  Decimal  @db.Decimal(5, 2)
  taskOnTimeScore   Decimal  @db.Decimal(5, 2)
  productivityScore Decimal  @db.Decimal(5, 2)
  qualityScore      Decimal  @db.Decimal(5, 2)
  attendanceScore   Decimal  @db.Decimal(5, 2)
  
  globalScore       Decimal  @db.Decimal(5, 2)
  grade             Grade
  
  computedAt        DateTime @default(now())
  
  @@unique([employeeId, date])
  @@index([date])
  @@index([globalScore])
  @@map("metric_snapshots")
}

enum Grade {
  A_PLUS
  A
  B
  C
  D
}

// =====================================================
// 3. FINANCE
// =====================================================

enum Currency {
  USD
  BOB
  PEN
}

model Wallet {
  id               String        @id @default(cuid())
  currency         Currency
  countryId        String
  country          Country       @relation(fields: [countryId], references: [id])
  
  name             String
  balance          Decimal       @db.Decimal(15, 2) @default(0)
  
  lastReconciledAt DateTime?
  lastReconciledBy String?
  lastMovementAt   DateTime?
  isActive         Boolean       @default(true)

  fxFromOps        FxOperation[] @relation("FromWallet")
  fxToOps          FxOperation[] @relation("ToWallet")
  payments         Payment[]
  
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  
  @@unique([currency, countryId])
  @@map("wallets")
}

model FxOperation {
  id            String   @id @default(cuid())
  
  fromWalletId  String
  fromWallet    Wallet   @relation("FromWallet", fields: [fromWalletId], references: [id])
  
  toWalletId    String
  toWallet      Wallet   @relation("ToWallet", fields: [toWalletId], references: [id])
  
  amountFrom    Decimal  @db.Decimal(15, 2)
  amountTo      Decimal  @db.Decimal(15, 2)
  rate          Decimal  @db.Decimal(12, 6)
  fee           Decimal  @db.Decimal(10, 2) @default(0)
  
  exchangeHouse String?
  receiptUrl    String?
  notes         String?
  
  performedById String
  performedAt   DateTime @default(now())
  
  reversedById  String?  // Append-only: edits create reversals
  
  createdAt     DateTime @default(now())
  
  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([performedAt])
  @@map("fx_operations")
}

model Payment {
  id              String        @id @default(cuid())
  
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id])
  
  walletId        String
  wallet          Wallet        @relation(fields: [walletId], references: [id])
  
  period          String
  
  amountLocal     Decimal       @db.Decimal(12, 2)
  currencyLocal   Currency
  amountUsdEquiv  Decimal       @db.Decimal(12, 2)
  rateApplied     Decimal       @db.Decimal(12, 6)
  
  status          PaymentStatus @default(PENDING)
  
  scheduledDate   DateTime
  paidDate        DateTime?
  
  proofUrl        String?
  notes           String?

  baseSalary      Decimal?      @db.Decimal(12, 2) @map("base_salary")
  bonusAmount     Decimal?      @db.Decimal(12, 2) @map("bonus_amount")
  bonusReason     String?                           @map("bonus_reason")

  reversedById    String?  // Append-only
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([employeeId])
  @@index([period])
  @@index([status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SCHEDULED
  PAID
  PARTIAL
  CANCELLED
  REVERSED
}

model CashBox {
  id                  String            @id @default(cuid())
  name                String            @unique
  clinicId            String?
  
  currency            Currency          @default(USD)
  balance             Decimal           @db.Decimal(12, 2) @default(0)
  lowBalanceThreshold Decimal           @db.Decimal(12, 2) @default(100)
  
  responsibleUserId   String?
  
  transactions        CashTransaction[]
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  @@map("cash_boxes")
}

model CashTransaction {
  id            String              @id @default(cuid())
  cashBoxId     String
  cashBox       CashBox             @relation(fields: [cashBoxId], references: [id])
  
  type          CashTransactionType
  amount        Decimal             @db.Decimal(12, 2)
  
  category      CashCategory
  description   String
  
  receiptUrl    String?

  performedById String
  performedAt   DateTime            @default(now())

  reversedById  String?  // Append-only

  // Fase 4 — Caja Chica ↔ Wallet: si un DEPÓSITO se financió desde una
  // cartera, aquí guardamos cuál. Ese monto cuenta como salida de esa wallet
  // (en su misma moneda). Opcional: depósitos sin origen no afectan wallets.
  sourceWalletId String?

  createdAt     DateTime            @default(now())

  @@index([cashBoxId])
  @@index([performedAt])
  @@index([category])
  @@index([sourceWalletId])
  @@map("cash_transactions")
}

enum CashTransactionType {
  DEPOSIT
  EXPENSE
}

enum CashCategory {
  MEDICAL_SUPPLIES
  TRANSPORT
  FOOD
  OFFICE
  UTILITIES
  MAINTENANCE
  CALACOTO
  RECORDINGS
  VIATICOS
  OTHER
}

// =====================================================
// 4. EXTERNAL RELATIONS
// =====================================================

model Lawyer {
  id               String            @id @default(cuid())
  userId           String?           @unique
  user             User?             @relation(fields: [userId], references: [id])

  entityType       LawyerEntityType

  firstName        String?
  lastName         String?
  firmName         String?

  parentFirmId     String?
  parentFirm       Lawyer?           @relation("FirmMembers", fields: [parentFirmId], references: [id])
  members          Lawyer[]          @relation("FirmMembers")

  email            String            @unique
  phone            String?
  address          String?

  // Phoenix 2026-06-06 (B.30/B.31): campos extra para catálogo de Bufetes
  city             String?           // Provo, West Valley, etc.
  state            String?           // ISO state code (UT)
  zip              String?           // ZIP code del member (puede diferir del bufete)
  barNumber        String?           // Número de colegiado (solo ATTORNEY)
  recoveryRate     Float?            // % de honorarios típico, ej. 33.3 = 33.3% (solo ATTORNEY)
  memberRole       LawyerMemberRole? // solo aplica si parentFirmId is set
  notes            String?           // notas internas de Edson (privadas)
  paymentSpeed     PaymentSpeed?     // marca rápido/lento para badge en B.30
  caseflowFlags    String[]          @default([]) // PIP-COVERED, MED-PAY, etc.

  status           ExternalStatus    @default(ACTIVE)

  commissionConfig CommissionConfig?

  referrals        Patient[]         @relation("LawyerReferrer")
  commissions      Commission[]      @relation("LawyerCommission")

  // Phoenix 2026-06-06: relaciones a Case
  casesAsLawFirm   Case[]            @relation("CaseLawFirm")
  casesAsAttorney  Case[]            @relation("CaseAttorney")

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([entityType])
  @@index([parentFirmId])
  @@index([city])
  @@map("lawyers")
}

// Phoenix 2026-06-06: rol del member dentro del bufete (B.31)
enum LawyerMemberRole {
  ATTORNEY        // Abogado titular
  CASE_MANAGER    // Manejador de casos · contacto operativo
  PARALEGAL       // Asistente legal certificado
  LEGAL_ASSISTANT // Asistente legal
  OTHER
}

// Phoenix 2026-06-06: badge de velocidad de pago para listado B.30
enum PaymentSpeed {
  FAST       // < 90 días promedio
  AVERAGE    // 90-150 días
  SLOW       // > 150 días (warn badge)
  UNKNOWN    // sin data aún
}

enum LawyerEntityType {
  FIRM
  INDEPENDENT
  FIRM_MEMBER
}

model Provider {
  id             String          @id @default(cuid())
  userId         String?         @unique
  user           User?           @relation(fields: [userId], references: [id])
  
  firstName      String
  lastName       String
  
  email          String          @unique
  phone          String?
  
  specialty      Specialty
  licenseNumber  String?
  
  status         ExternalStatus  @default(ACTIVE)
  
  serviceTariffs ServiceTariff[]
  
  referrals      Patient[]       @relation("ProviderReferrer")
  commissions    Commission[]    @relation("ProviderCommission")
  appointments   Appointment[]
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  
  @@map("providers")
}

enum ExternalStatus {
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
  TERMINATED
}

enum Specialty {
  RADIOLOGY
  NEUROLOGY
  ORTHOPEDICS
  PHYSICAL_THERAPY
  CHIROPRACTIC
  PAIN_MANAGEMENT
  PSYCHOLOGY
  GENERAL
  OTHER
}

model ServiceTariff {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  
  serviceName String
  amount      Decimal  @db.Decimal(10, 2)
  currency    Currency @default(USD)
  
  @@map("service_tariffs")
}

model Patient {
  id                 String          @id @default(cuid())
  
  patientCode        String          @unique
  
  firstName          String
  lastName           String
  email              String?   @unique
  phone              String?
  dateOfBirth        DateTime?
  
  accidentDate       DateTime?
  accidentType       AccidentType?
  insuranceCarrier   String?
  policyNumber       String?
  
  lawyerReferrerId   String?
  lawyerReferrer     Lawyer?         @relation("LawyerReferrer", fields: [lawyerReferrerId], references: [id])
  
  providerReferrerId String?
  providerReferrer   Provider?       @relation("ProviderReferrer", fields: [providerReferrerId], references: [id])
  
  status             PatientStatus   @default(NEW)

  // Intake preferences (capturadas en B.6 portal)
  preferredLanguage      String?
  emergencyContactName   String?
  emergencyContactPhone  String?

  // Responsable legal (requerido cuando el paciente es menor de edad)
  guardianName       String?
  guardianPhone      String?
  guardianRelation   String?   // "PARENT" | "MOTHER" | "FATHER" | "LEGAL_GUARDIAN" | "OTHER"

  appointments       Appointment[]
  commissions        Commission[]

  // Phoenix 2026-06-06: un paciente puede tener varios cases (varios MVAs)
  cases              Case[]          @relation("PatientCases")

  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([lawyerReferrerId])
  @@index([providerReferrerId])
  @@index([status])
  @@map("patients")
}

enum PatientStatus {
  NEW
  ACTIVE
  COMPLETED
  DISCHARGED
  INACTIVE
}

enum AccidentType {
  AUTO
  MOTORCYCLE
  PEDESTRIAN
  WORKPLACE
  OTHER
}

model Clinic {
  id           String        @id @default(cuid())
  name         String        @unique
  address      String?
  phone        String?
  
  appointments Appointment[]
  
  @@map("clinics")
}

model Appointment {
  id              String            @id @default(cuid())

  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])

  // Phoenix 2026-06-06: link al Case del paciente
  caseId          String?
  case            Case?             @relation("CaseAppointments", fields: [caseId], references: [id])

  clinicId        String
  clinic          Clinic            @relation(fields: [clinicId], references: [id])

  providerId      String?
  provider        Provider?         @relation(fields: [providerId], references: [id])

  scheduledFor    DateTime
  durationMinutes Int               @default(30)

  type            AppointmentType
  status          AppointmentStatus @default(SCHEDULED)

  notes           String?

  // B.14 Check-in: timestamp cuando recepción confirma la llegada del paciente
  checkedInAt     DateTime?

  // B.14.1 Firma de asistencia (paciente firma en tablet al llegar)
  attendanceSignedAt      DateTime?
  attendanceSignatureSvg  String?   @db.Text  // PNG base64 del canvas
  attendanceSignatureHash String?             // SHA-256(svg+appointmentId+timestamp)

  // B.16 Triaje — registro de signos vitales capturados por MA
  triageRecord    TriageRecord?

  // B.18 Nota de visita — firmada por el doctor
  visitNote       VisitNote?

  // B.20 Órdenes de laboratorio / imaging
  labOrders       LabOrder[]

  // B.19 Prescripciones electrónicas
  prescriptions   Prescription[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([patientId])
  @@index([caseId])
  @@index([clinicId])
  @@index([scheduledFor])
  @@index([status])
  @@map("appointments")
}

enum AppointmentType {
  AUTO_ACCIDENT
  FAMILY_PRACTICE
  URGENT_CARE
  FOLLOW_UP
  CONSULTATION
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN   // B.14: paciente llegó físicamente y hizo check-in en recepción
  IN_PROGRESS  // B.15: pasó a sala con el doctor
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING
}

// ─── Triage Record (B.16 — Medical Assistant) ─────────────────────────────
//
// Signos vitales capturados por el MA antes de la visita del doctor.
// Uno por Appointment. Se auto-sincroniza al abrir la nota del doctor (B.18).
//
model TriageRecord {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // ─── Height ──────────────────────────────────────────────────────────────
  heightFt       Int?        // pies
  heightIn       Int?        // pulgadas
  heightCm       Float?      // cms auto-calculado (stored for audit)

  // ─── Weight ───────────────────────────────────────────────────────────────
  weightLbs      Int?
  weightOz       Int?
  weightKg       Float?      // kgs auto-calculado

  // ─── Blood Pressure ───────────────────────────────────────────────────────
  systolicMmhg   Int?
  diastolicMmhg  Int?

  // ─── Pulse & Temperature ─────────────────────────────────────────────────
  pulseBpm       Int?
  tempFahrenheit Float?
  tempCelsius    Float?      // auto-calculado

  // ─── Oxygen ───────────────────────────────────────────────────────────────
  o2Saturation   Int?        // porcentaje (e.g., 98)
  onRoomAir      Boolean     @default(true)

  // ─── Vision Acuity ────────────────────────────────────────────────────────
  visualAcuityRight String?  // "20" (denominator de 20/X)
  visualAcuityLeft  String?
  visualAcuityBoth  String?
  visionCorrected   Boolean  @default(false) // false=Uncorrected, true=Corrected

  // ─── Chief Complaint ──────────────────────────────────────────────────────
  chiefComplaint String?     @db.Text

  // ─── Meta ─────────────────────────────────────────────────────────────────
  capturedByUserId String?
  capturedByName   String?   @default("MA")

  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("triage_records")
}

// ─── B.18 VisitNote ───────────────────────────────────────────────────────────

enum VisitNoteStatus {
  DRAFT   // Auto-guardado, no firmado
  SIGNED  // Firmado por doctor — inmutable
  VOIDED  // Anulado (solo Super Admin)
}

/// Nota clínica SOAP generada por el doctor durante la visita.
/// Se crea como DRAFT al abrir B.18 y queda SIGNED al firmar.
model VisitNote {
  id             String          @id @default(cuid())
  appointmentId  String          @unique
  appointment    Appointment     @relation(fields: [appointmentId], references: [id])

  // Plantilla usada al inicio de la visita (snapshot reference)
  templateId     String?
  template       Template?       @relation(fields: [templateId], references: [id])

  // ─── Vitales (copia editable del triaje, separada de TriageRecord) ──────
  heightFt       Int?
  heightIn       Int?
  heightCm       Float?
  weightLbs      Int?
  weightOz       Int?
  weightKg       Float?
  systolicMmhg   Int?
  diastolicMmhg  Int?
  pulseBpm       Int?
  respRate       Int?            // Frecuencia respiratoria
  tempFahrenheit Float?
  tempCelsius    Float?
  painScale      Int?            // 0–10
  o2Saturation   Int?
  onRoomAir      Boolean?

  // ─── Secciones SOAP ─────────────────────────────────────────────────────
  chiefComplaint String?         @db.Text   // QUEJA_PRINCIPAL
  hpi            String?         @db.Text   // HPI
  ros            String?         @db.Text   // ROS
  physicalExam   String?         @db.Text   // EXAMEN_FISICO
  assessment     String?         @db.Text   // EVALUACIONES
  plan           String?         @db.Text   // PLAN

  // ─── Diagnósticos (1:N) ─────────────────────────────────────────────────
  diagnoses      VisitNoteDiagnosis[]

  // ─── B.21 CPT services assigned to this visit ───────────────────────────
  serviceCodes   VisitServiceCode[]

  // ─── B.20 Lab/imaging orders ────────────────────────────────────────────
  labOrders      LabOrder[]

  // ─── B.19 Prescripciones electrónicas ───────────────────────────────────
  prescriptions  Prescription[]

  // ─── Estado y firma ─────────────────────────────────────────────────────
  status         VisitNoteStatus @default(DRAFT)
  signedAt       DateTime?
  signedById     String?         // userId snapshot
  signedByName   String?         // nombre snapshot

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
  @@index([status])
  @@map("visit_notes")
}

// ─── B.21 VisitServiceCode ────────────────────────────────────────────────────
/// CPT / HCPCS codes asignados a una visita por el doctor antes de firmar.
/// fee_override permite ajustar el fee del catálogo por visita (self-pay, etc.).
/// Se crea junto con la nota DRAFT y queda locked al firmar.
/// Tablas en DB: migration 20260608020000_visit_service_codes.sql
/// NOTA: usar db.$queryRaw hasta regenerar Prisma client.
model VisitServiceCode {
  id            String       @id @default(cuid())
  visitNoteId   String
  visitNote     VisitNote    @relation(fields: [visitNoteId], references: [id], onDelete: Cascade)
  serviceCodeId String?
  serviceCode   ServiceCode? @relation(fields: [serviceCodeId], references: [id], onDelete: SetNull)

  // Snapshot al asignar
  cptCode       String
  description   String
  feeCatalog    Decimal  @db.Decimal(10,2)
  feeOverride   Decimal? @db.Decimal(10,2)  // null = usar feeCatalog
  overrideReason String?

  modifier      String?
  units         Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([visitNoteId, cptCode])
  @@index([visitNoteId])
  @@map("visit_service_codes")
}

// ─── B.20 Lab/Imaging Order ───────────────────────────────────────────────────
/// Orden de laboratorio, imaging o cardiología creada por el doctor
/// desde la nota SOAP. Aparece como "acción requerida" al resultar.
/// Tablas en DB: migration 20260608030000_lab_orders.sql
/// NOTA: usar db.$queryRaw hasta regenerar Prisma client.

enum LabOrderType {
  LABORATORY
  IMAGING
  CARDIOLOGY
  OTHER
}

enum LabOrderUrgency {
  STAT
  URGENT
  ROUTINE
}

enum LabOrderStatus {
  ORDERED
  IN_PROGRESS
  RESULTED
  VOIDED
}

model LabOrder {
  id            String          @id @default(cuid())
  appointmentId String
  appointment   Appointment     @relation(fields: [appointmentId], references: [id])
  visitNoteId   String?
  visitNote     VisitNote?      @relation(fields: [visitNoteId], references: [id], onDelete: SetNull)

  orderType          LabOrderType
  studyName          String
  loincCode          String?
  clinicalIndication String       @db.Text
  urgency            LabOrderUrgency @default(ROUTINE)
  preferredCenter    String?
  icd10Codes         String[]    @default([])

  status        LabOrderStatus @default(ORDERED)
  orderedAt     DateTime       @default(now())
  orderedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
  @@index([visitNoteId])
  @@map("lab_orders")
